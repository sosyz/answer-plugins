{
  "name": "connector-passkey-v2",
  "version": "1.0.0",
  "description": "Passkey (WebAuthn) connector for Apache Answer",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/connector-passkey-v2.umd.js",
  "module": "./dist/connector-passkey-v2.es.js",
  "types": "./dist/connector-passkey-v2.d.ts",
  "exports": {
    ".": {
      "import": "./dist/connector-passkey-v2.es.js",
      "require": "./dist/connector-passkey-v2.umd.js"
    }
  },
  "scripts": {
    "dev": "vite build --mode development --watch",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "peerDependencies": {
    "@types/react": "^18.0.17",
    "react": "^18.2.0",
    "react-bootstrap": "^2.10.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^11.18.3"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vite-plugin-css-injected-by-js": "^3.3.0",
    "vite-plugin-dts": "^3.9.1"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^10.0.0"
  }
}
